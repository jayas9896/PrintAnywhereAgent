<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <!--
    Phase 2c - PrintAnywhereAgent MSI authoring.

    UpgradeCode is the stable GUID that identifies the product
    across versions. Generated once; NEVER changed. A new
    UpgradeCode means Windows treats the new MSI as a different
    product (won't replace the old install, won't show as upgrade
    in Add/Remove Programs) - operators would end up with two
    PrintAnywhere Agent entries.
  -->
  <Package
      Name="PrintAnywhere Agent"
      Manufacturer="Dhruvanta Systems"
      Version="$(PrintAnywhereAgentVersion)"
      UpgradeCode="9C7E5E13-3D7A-4E5B-9F42-2F2D5B7B6E11"
      Scope="perUser"
      Compressed="yes">

    <SummaryInformation Description="PrintAnywhere Agent for Windows" />

    <!-- In-place upgrade. AllowSameVersionUpgrades=yes so a re-run
         of the same version installer (e.g. operator clicks the
         setup EXE twice) repairs instead of conflicting. -->
    <MajorUpgrade
        AllowSameVersionUpgrades="yes"
        DowngradeErrorMessage="A newer version of PrintAnywhere Agent is already installed. Uninstall it first from Settings -> Apps before installing this version." />

    <!-- Single .cab embedded inside the MSI so operators only have
         one file to download. -->
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- Per-user install layout - mirrors the existing
         %LOCALAPPDATA%\Dhruvanta Systems\PrintAnywhereAgent\
         printanywhere-agent-vX.Y.Z\ convention so the native
         tray's InstallLayout.Discover() finds it. -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ManufacturerDir" Name="Dhruvanta Systems">
        <Directory Id="ProductDir" Name="PrintAnywhereAgent">
          <Directory Id="INSTALLDIR" Name="printanywhere-agent-v$(PrintAnywhereAgentVersion)">
            <!-- Phase 2c follow-up: the full release-bundle harvest
                 (PrintAnywhereAgent.exe + dist/ + node-win-x64/ +
                 scripts/ + assets/ + config/ + node_modules/ + the
                 root .cmd launchers) is materialised by
                 scripts/harvest-msi-payload.mjs into Harvested.wxs.
                 That fragment declares a ComponentGroup named
                 PayloadComponents wired up under this INSTALLDIR via
                 a DirectoryRef. We just need a tiny anchor component
                 here that owns the RemoveFolder for INSTALLDIR /
                 ProductDir / ManufacturerDir so uninstall takes the
                 outer dirs out. The harvested per-file components
                 own RemoveFolder for their own subdirs. -->
            <Component Id="InstallDirAnchorComponent"
                       Guid="6A0F4C2B-7D5E-4A2C-9E11-3F8A1D7B5C44">
              <RegistryValue Root="HKCU"
                             Key="Software\Dhruvanta Systems\PrintAnywhereAgent"
                             Name="InstallDirAnchor"
                             Type="integer"
                             Value="1"
                             KeyPath="yes" />
              <RemoveFolder Id="RemoveInstallDir"
                            Directory="INSTALLDIR"
                            On="uninstall" />
              <RemoveFolder Id="RemoveProductDir"
                            Directory="ProductDir"
                            On="uninstall" />
              <RemoveFolder Id="RemoveManufacturerDir"
                            Directory="ManufacturerDir"
                            On="uninstall" />
            </Component>
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcut targeting the native tray EXE. -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Dhruvanta Systems" />
    </StandardDirectory>

    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcuts" Guid="*">
        <Shortcut Id="ApplicationStartMenuShortcut"
                  Name="PrintAnywhere Agent"
                  Description="Open the PrintAnywhere Agent tray controls."
                  Target="[INSTALLDIR]PrintAnywhereAgent.exe"
                  WorkingDirectory="INSTALLDIR" />
        <RemoveFolder Id="CleanUpProgramsFolder"
                      Directory="ApplicationProgramsFolder"
                      On="uninstall" />
        <!-- Per-user MSIs need a per-user registry key to anchor
             the component (Windows uses it as the KeyPath for
             reference counting on uninstall). -->
        <RegistryValue Root="HKCU"
                       Key="Software\Dhruvanta Systems\PrintAnywhereAgent"
                       Name="StartMenuShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- ARP (Add/Remove Programs) polish. NOTE: ARPNOREPAIR /
         ARPNOMODIFY are set by WixUI_Minimal already; defining them
         here too triggers WIX duplicate-property errors. -->
    <Property Id="ARPCONTACT" Value="support@dhruvantasystems.com" />
    <Property Id="ARPHELPLINK" Value="https://printanywhere.dhruvantasystems.com/" />

    <!-- KAN-451: opt-in clean install. Default "0" PRESERVES pairing/identity/
         printer state across reinstalls and upgrades (the normal case). Set
         CLEANINSTALL=1 (e.g. `msiexec /i PrintAnywhereAgent.msi CLEANINSTALL=1`)
         to reset this machine. Secure="yes" allows it through a UAC-elevated
         install. The derived CLEANINSTALLARG token (""/" -CleanInstall") is set
         only at runtime by the conditional SetProperty below — left undeclared
         here on purpose: an empty-valued Property is dropped by WiX (PropertyUseless)
         and an unset property already formats to "" in the command string. -->
    <Property Id="CLEANINSTALL" Value="0" Secure="yes" />

    <!-- KAN-425: Add/Remove Programs icon. <Icon> EMBEDS the file into
         the MSI itself (it is not a runtime payload file), so it only
         needs a path that exists at WiX compile time. Point at the
         committed repo-root assets icon, relative to this .wixproj dir
         (native-shell/PrintAnywhereAgent.Installer/ -> ..\..\assets),
         rather than the staged payload — build-native-tray.mjs does NOT
         copy any .ico into the payload, so the old
         $(var.PayloadSource)\dhruvanta-agent.ico never existed on the
         CI runner (WIX0103). -->
    <Icon Id="PrintAnywhereAgent.ico" SourceFile="..\..\assets\dhruvanta-agent.ico" />
    <Property Id="ARPPRODUCTICON" Value="PrintAnywhereAgent.ico" />

    <Feature Id="MainFeature"
             Title="PrintAnywhere Agent"
             Level="1"
             Display="expand"
             AllowAdvertise="no"
             InstallDefault="local"
             AllowAbsent="no">
      <ComponentRef Id="InstallDirAnchorComponent" />
      <ComponentRef Id="ApplicationShortcuts" />
      <!-- PayloadComponents is generated by
           scripts/harvest-msi-payload.mjs into Harvested.wxs and
           wires every staged-bundle file. -->
      <ComponentGroupRef Id="PayloadComponents" />
    </Feature>

    <!-- ===================================================================
         KAN-425: per-user provisioning CustomAction.

         PRIMARY FIX for the v0.1.37 symptom (operator installed the MSI
         and saw nothing for ~5 min: no tray icon, no Add/Remove entry,
         the local UI never loaded). Root cause: the MSI laid the files
         down but NOTHING ever ran install-release.ps1, so the per-user
         setup (tray launch, runtime start on 127.0.0.1:43100, logon
         autostart, shortcuts) never happened.

         This deferred, IMPERSONATED CustomAction runs the bundled
         install-release.ps1 as the installing user (NO elevation — this
         is a perUser MSI) right after the files are committed. It does
         ONLY the per-user steps, all of which need no admin:
           * launches the tray (-StartTray) -> tray icon appears
           * starts the agent runtime -> https://127.0.0.1:43100 serves
           * registers logon autostart (-RegisterStartupTask)
           * creates Desktop / Start Menu shortcuts (-CreateShortcuts)

         The two admin-only bits inside install-release.ps1 (hosts-file
         entry + cert trust for the pretty domain
         local.printanywhere.dhruvantasystems.com) DEGRADE TO A WARNING
         when not elevated; the script does NOT throw for them in the
         non-elevated path. The pretty domain is finished later via the
         in-app "Repair local URL setup" banner (KAN-294,
         src/ui/localHttpsRepair.ts) which fires a single UAC prompt
         from the running app. So we intentionally do NOT elevate here.

         Sequencing:
           * SetProperty builds the command line (deferred CAs cannot
             read [INSTALLDIR]/[LocalAppDataFolder] at execution time, so
             we resolve them now and stash the formatted string into the
             property whose name == the deferred CA Id; MSI surfaces it
             as CustomActionData).
           * The CA runs deferred + impersonated, AFTER InstallFiles,
             only on install/upgrade (NOT REMOVE), and Return="ignore"
             so an expected non-elevated hosts/cert warning (or a
             transient tray relaunch hiccup) never aborts an otherwise
             good install. A genuine hard failure is logged but the file
             payload is already in place and the operator can relaunch
             from the Start Menu shortcut.

         DataDir is passed explicitly and matches
         install-release.ps1's Resolve-DefaultDataDir output for a
         managed %LOCALAPPDATA% install, so the MSI, the scheduled task,
         and the tray all agree on one data directory.

         Silent auto-update (msiexec /quiet, run by check-update.ps1)
         executes this same CA. That is fine and intended: it is
         per-user (no UAC), install-release.ps1 is idempotent, single-
         instances the tray (Stop-ExistingTrayControllers before
         -StartTray), and ends with a running tray — so a quiet update
         self-heals the runtime without any interactive prompt.
         =================================================================== -->
    <!-- KAN-451: fold the optional " -CleanInstall" flag into the provisioning
         command only when the operator asked for a reset (CLEANINSTALL=1).
         CLEANINSTALLARG defaults to "" so the normal install preserves data.
         Scheduled After CostFinalize — well before the SetProperty below that
         builds the command string — so [CLEANINSTALLARG] is already resolved
         when that string is formatted. (Kept as a separate action that targets
         a separate property so the proven RunAgentProvisioning SetProperty is
         unchanged except for the appended token.) -->
    <SetProperty Id="CLEANINSTALLARG"
                 After="CostFinalize"
                 Sequence="execute"
                 Condition="CLEANINSTALL=&quot;1&quot;"
                 Value=" -CleanInstall" />

    <SetProperty Id="RunAgentProvisioning"
                 Before="RunAgentProvisioning"
                 Sequence="execute"
                 Value="&quot;[System64Folder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File &quot;[INSTALLDIR]scripts\install-release.ps1&quot; -DataDir &quot;[LocalAppDataFolder]Dhruvanta Systems\PrintAnywhereAgent\data&quot; -Port 43100 -RegisterStartupTask -CreateShortcuts -StartTray[CLEANINSTALLARG]" />

    <!-- BinaryRef MUST use the arch-suffixed preprocessor variable; a
         hardcoded literal (e.g. Wix4UtilCA_X86) fails the WiX link with
         "The identifier 'Binary:Wix4UtilCA_X86' could not be found" when
         the package builds for a different arch. $(sys.BUILDARCHSHORT)
         resolves to the matching emitted util-CA binary id. -->
    <CustomAction Id="RunAgentProvisioning"
                  BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />


    <InstallExecuteSequence>
      <Custom Action="RunAgentProvisioning" After="InstallFiles" Condition="NOT REMOVE" />
    </InstallExecuteSequence>

    <!-- WixUI_Minimal wizard: License -> "Install" -> Finish. No
         install-directory picker - this is a per-user MSI pinned to
         %LOCALAPPDATA%, the operator can't choose. License text
         comes from License.rtf next to this wxs. -->
    <ui:WixUI Id="WixUI_Minimal" />
    <!-- KAN-425: progress-page status text. WiX v5 requires ProgressText
         to be a child of <UI> (not <Package> directly), so it lives in this
         standalone <UI> which merges with the WixUI_Minimal dialog set above. -->
    <UI>
      <ProgressText Action="RunAgentProvisioning" Message="Configuring and starting PrintAnywhere Agent..." />
    </UI>
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

  </Package>
</Wix>
