# Copy this file to config/agent.env to override local runtime settings.
# The production PrintAnywhere backend URL is prefilled in the local UI.
# Override this only for local testing or support-directed cutover.

PRINTANYWHERE_AGENT_PORT=43100
PRINTANYWHERE_AGENT_DATA_DIR=./data
PRINTANYWHERE_AGENT_SIMULATE_PRINT=false
# PRINTANYWHERE_AGENT_DEFAULT_BACKEND_URL=https://api.dhruvantasystems.net/printanywhere
